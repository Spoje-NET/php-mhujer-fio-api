#!/usr/bin/make -f
PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell jq -r '.name' composer.json)

%:
	dh $@

override_dh_install:
	dh_install
	install -m 644 debian/autoload.php \
	    debian/php-mhujer-fio-api/usr/share/php/FioApi/autoload.php
	sed -i 's/certificatePath;/certificatePath="\/usr\/share\/ca-certificates\/Geotrust_PCA_G3_Root.pem";/' \
	    debian/php-mhujer-fio-api/usr/share/php/FioApi/Downloader.php
	sed -i "s|'unknown'|'$(PKG_SOURCE)'|" \
	    debian/php-mhujer-fio-api/usr/share/php/FioApi/autoload.php
	sed -i "s|'0.0.0'|'$(PKG_VERSION)'|" \
	    debian/php-mhujer-fio-api/usr/share/php/FioApi/autoload.php
